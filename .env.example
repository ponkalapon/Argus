# ─── LLM endpoint ──────────────────────────────────────────
ARGUS_API_KEY=sk-...
ARGUS_BASE_URL=https://api.openai.com/v1
ARGUS_MODEL=gpt-4o-mini

# ─── Server ─────────────────────────────────────────────────
ARGUS_PORT=3456

# ─── Data directory (default: ./data) ───────────────────────
ARGUS_DATA_DIR=

# ─── Retry / timeout ────────────────────────────────────────
# LLMClient retries up to 90 times with 30 s per-attempt timeout.
# These are compile-time defaults in retry.ts — change there if needed.
# LLM_MAX_RETRIES=90
# LLM_TIMEOUT_MS=30000
