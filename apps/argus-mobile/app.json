{
  "expo": {
    "name": "Argus",
    "slug": "argus",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "scheme": "argus",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dimap.argus"
    },
    "splash": {
      "backgroundColor": "#000000",
      "resizeMode": "contain"
    },
    "android": {
      "package": "com.dimap.argus",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/icon_foreground.png"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow AgentAI to access your calendar",
          "remindersPermission": "Allow AgentAI to access your reminders"
        }
      ],
      "expo-sharing",
      "expo-splash-screen",
      "@react-native-voice/voice"
    ]
  }
}
